# Скопируйте в .env и подставьте свои значения:
#   cp .env.example .env
#
# Подгрузка перед скриптом публикации:
#   set -a && source .env && set +a && ./scripts/publish-latest-tag-to-public.sh

# Пример: git@github.com:org/public-sdk.git
PUBLIC_GIT_URL='git@github.com:your-org/your-public-repo.git'

SOURCE_BRANCH=master
PUBLIC_BRANCH=master

PUBLISH_AUTHOR_NAME='Public Release'
PUBLISH_AUTHOR_EMAIL='you@example.com'
# Если пусто, скрипт подставит те же значения, что у author
PUBLISH_COMMITTER_NAME=
PUBLISH_COMMITTER_EMAIL=

# version — по semver-подобному имени тега; date — по дате создания тега
TAG_SORT=version

DRY_RUN=0
FORCE_PUSH_TAG=0
